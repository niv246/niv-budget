# Database (Railway injects this automatically)
DATABASE_URL=postgresql://user:pass@host:5432/niv_budget

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_WEBHOOK_URL=https://your-backend.up.railway.app/api/telegram/webhook

# Auth tokens (generate random strings)
OWNER_ACCESS_TOKEN=generate_random_token_here
VIEWER_ACCESS_TOKEN=generate_different_token_here

# App
PORT=3001
NODE_ENV=production
FRONTEND_URL=https://your-frontend.up.railway.app
